        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "${SUPABASE_SERVICE_ROLE_KEY}"
            },
            {
              "name": "Authorization",
              "value": "Bearer ${SUPABASE_SERVICE_ROLE_KEY}"
            }
          ]
        },
        "options": {}
      },
      "id": "d1a1b1c1-0009-4000-8000-000000000009",
      "name": "Fetch Recent Context",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 500]
    },
    {
      "parameters": {
        "jsCode": "const ownerData = $('Parse Owner Message').first().json;\nconst recentLogs = $('Fetch Recent Context').first().json;\n\nconst contextSummary = Array.isArray(recentLogs)\n  ? recentLogs.map(l => `[${l.event_type}] ${l.summary || ''}`).join('\\n')\n  : 'No recent activity logs available.';\n\nreturn [{\n  json: {\n    ownerMessage: ownerData.ownerMessage,\n    ownerPhone: ownerData.ownerPhone,\n    context: contextSummary\n  }\n}];"
      },
      "id": "d1a1b1c1-0010-4000-8000-000000000010",
      "name": "Build LLM Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [920, 500]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.minimax.io/v1/chat/completions",
        "sendHeaders": true,
