          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'minimax-m2.7', messages: [ { role: 'system', content: 'You are the AI business assistant for Saffron Kitchen. You communicate with the business owner via WhatsApp. You are their AI Chief of Staff.\\n\\nYour role:\\n1. Reports — tell them what is happening with their business\\n2. Asks — proactively request information needed to serve customers better\\n3. Learns — absorb every piece of information the owner shares\\n4. Advises — share insights, trends, and suggestions based on data\\n\\nCommunication style: concise, bullet points, include numbers. Be direct. Casual but professional.\\n\\nWhen the owner sends updates (menu changes, closures, pricing, etc.), acknowledge and confirm what you understood. When they ask questions, answer from activity logs context.\\n\\nRecent activity context:\\n' + $json.context }, { role: 'user', content: $json.ownerMessage } ], max_tokens: 600, temperature: 0.5 }) }}",
        "options": {}
      },
      "id": "d1a1b1c1-0011-4000-8000-000000000011",
      "name": "Owner Brain Response (MiniMax)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1160, 500]
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst replyText = response.choices?.[0]?.message?.content || 'I received your message but could not process it right now. I will follow up shortly.';\nconst ownerPhone = $('Build LLM Context').first().json.ownerPhone;\nconst ownerMessage = $('Build LLM Context').first().json.ownerMessage;\n\nreturn [{\n  json: {\n    replyText: replyText,\n    ownerPhone: ownerPhone,\n    ownerMessage: ownerMessage\n  }\n}];"
      },
      "id": "d1a1b1c1-0012-4000-8000-000000000012",
      "name": "Extract Reply",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1400, 500]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://sybzqktipimbmujtowoz.supabase.co/rest/v1/activity_logs",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
