            }
          ]
        },
        "options": {}
      },
      "id": "d1a1b1c1-0003-4000-8000-000000000003",
      "name": "Fetch Activity Logs (Briefing)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 200]
    },
    {
      "parameters": {
        "jsCode": "const logs = $input.first().json;\nconst now = new Date();\nconst yesterday = new Date(now.getTime() - 24 * 60 * 60 * 1000);\n\n// Filter to last 24 hours\nconst recentLogs = Array.isArray(logs) ? logs.filter(l => new Date(l.created_at) >= yesterday) : [];\n\n// Count by event type\nconst counts = {};\nfor (const log of recentLogs) {\n  counts[log.event_type] = (counts[log.event_type] || 0) + 1;\n}\n\nconst summaries = recentLogs.map(l => `[${l.event_type}] ${l.summary || ''}`).join('\\n');\n\nreturn [{\n  json: {\n    totalEvents: recentLogs.length,\n    eventCounts: counts,\n    summaries: summaries,\n    period: 'last_24h',\n    date: now.toISOString().split('T')[0]\n  }\n}];"
      },
      "id": "d1a1b1c1-0004-4000-8000-000000000004",
      "name": "Summarize Activity",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.minimax.io/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer ${MINIMAX_API_KEY}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'minimax-m2.7', messages: [ { role: 'system', content: 'You are the AI business assistant for Saffron Kitchen. You communicate with the business owner via WhatsApp. You are their AI Chief of Staff. Be concise — they are busy running a restaurant. Use bullet points, include numbers when available. Be proactive, not just reactive. Keep the morning briefing under 500 characters. Use emoji sparingly.' }, { role: 'user', content: 'Compile a concise daily morning briefing from these activity logs from the last 24 hours. Include: total inquiries, bookings, leads, complaints, and any items needing attention.\\n\\nDate: ' + $json.date + '\\nTotal events: ' + $json.totalEvents + '\\nEvent breakdown: ' + JSON.stringify($json.eventCounts) + '\\nActivity summaries:\\n' + $json.summaries } ], max_tokens: 500, temperature: 0.4 }) }}",
        "options": {}
      },
      "id": "d1a1b1c1-0005-4000-8000-000000000005",
      "name": "Generate Briefing (MiniMax)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [920, 200]
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst briefing = response.choices?.[0]?.message?.content || 'No briefing data available today.';\n\nreturn [{\n  json: {\n    briefingText: briefing,\n    date: $('Summarize Activity').first().json.date\n  }\n}];"
      },
      "id": "d1a1b1c1-0006-4000-8000-000000000006",
      "name": "Extract Briefing Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1160, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://sybzqktipimbmujtowoz.supabase.co/rest/v1/activity_logs",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "${SUPABASE_SERVICE_ROLE_KEY}"
            },
            {
              "name": "Authorization",
              "value": "Bearer ${SUPABASE_SERVICE_ROLE_KEY}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "return=minimal"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ client_id: '3bd50557-6680-43b9-bb8e-261c7f8a19d2', event_type: 'brain_briefing', summary: 'Daily morning briefing sent — ' + $json.date, payload: { briefing: $json.briefingText, direction: 'outbound' } }) }}",
        "options": {}
      },
      "id": "d1a1b1c1-0007-4000-8000-000000000007",
      "name": "Log Briefing to Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1400, 200]
    },
    {
      "parameters": {
        "jsCode": "// Parse the owner's incoming WhatsApp message from webhook\nconst body = $input.first().json.body || $input.first().json;\n\nconst ownerMessage = body.message?.text || body.text || body.Body || body.message || '';\nconst ownerPhone = body.from || body.From || body.sender || '';\nconst messageId = body.message_id || body.MessageSid || '';\n\nreturn [{\n  json: {\n    ownerMessage: typeof ownerMessage === 'string' ? ownerMessage : JSON.stringify(ownerMessage),\n    ownerPhone: ownerPhone,\n    messageId: messageId,\n    receivedAt: new Date().toISOString()\n  }\n}];"
      },
      "id": "d1a1b1c1-0008-4000-8000-000000000008",
      "name": "Parse Owner Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 500]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://sybzqktipimbmujtowoz.supabase.co/rest/v1/activity_logs",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "client_id",
              "value": "eq.3bd50557-6680-43b9-bb8e-261c7f8a19d2"
            },
            {
              "name": "order",
              "value": "created_at.desc"
            },
            {
              "name": "limit",
              "value": "20"
