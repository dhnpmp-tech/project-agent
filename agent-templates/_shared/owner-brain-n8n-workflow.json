        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ client_id: '3bd50557-6680-43b9-bb8e-261c7f8a19d2', event_type: 'brain_interaction', summary: 'Owner message handled: ' + ($json.ownerMessage || '').substring(0, 100), payload: { direction: 'inbound', owner_message: $json.ownerMessage, reply: $json.replyText } }) }}",
        "options": {}
      },
      "id": "d1a1b1c1-0013-4000-8000-000000000013",
      "name": "Log Interaction to Supabase",
