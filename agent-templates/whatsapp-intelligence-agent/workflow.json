    {
      "parameters": {
        "jsCode": "// Merge all response branches into a single output\nconst items = $input.all();\nconst item = items[0];\n\n// Extract response text from LLM output or code node\nlet responseText = '';\nif (item.json.response) {\n  responseText = item.json.response;\n} else if (item.json.message?.content) {\n  responseText = item.json.message.content;\n} else if (typeof item.json.text === 'string' && item.json.intent) {\n  responseText = 'Thank you for your message. How can I help you?';\n}\n\n// Get original message data (from Parse Classification node)\nconst origData = $('Parse Classification').first().json;\n\nreturn [{\n  json: {\n    phone: origData.from,\n    phoneNumberId: origData.phoneNumberId,\n    responseText,\n    intent: origData.intent,\n    sentiment: origData.sentiment,\n    language: origData.language,\n    escalate: item.json.escalate || false,\n    originalMessage: origData.text,\n    contactName: origData.contactName\n  }\n}];"
      },
