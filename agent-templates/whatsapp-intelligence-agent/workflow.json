{
  "name": "WhatsApp Intelligence Agent — {{COMPANY_NAME}}",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "whatsapp-webhook",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "WhatsApp Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [200, 300]
    },
    {
      "parameters": {
        "jsCode": "// Extract message data from WhatsApp webhook payload\nconst body = $input.first().json.body;\n\n// WhatsApp Cloud API payload structure\nconst entry = body?.entry?.[0];\nconst changes = entry?.changes?.[0];\nconst value = changes?.value;\n\nif (!value?.messages?.[0]) {\n  // This is a status update, not a message\n  return [{ json: { skip: true } }];\n}\n\nconst message = value.messages[0];\nconst contact = value.contacts?.[0];\n\nreturn [{\n  json: {\n    skip: false,\n    messageId: message.id,\n    from: message.from,\n    timestamp: message.timestamp,\n    type: message.type,\n    text: message.text?.body || message.interactive?.button_reply?.title || '',\n    contactName: contact?.profile?.name || 'Unknown',\n    phoneNumberId: value.metadata?.phone_number_id\n  }\n}];"
      },
      "id": "parse-webhook",
      "name": "Parse WhatsApp Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [420, 300]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.skip }}",
              "value2": true
            }
          ]
        }
      },
      "id": "skip-check",
      "name": "Is Message?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [620, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "{ \"status\": \"ok\" }"
      },
      "id": "respond-skip",
      "name": "Acknowledge (Skip)",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [820, 450]
    },
    {
      "parameters": {
        "jsCode": "// Load conversation history from Redis\n// Key: conv:{{CLIENT_ID}}:{phone}\nconst phone = $input.first().json.from;\nconst redisKey = `conv:{{CLIENT_ID}}:${phone}`;\n\n// This node connects to Redis via the Redis credentials\n// In production, use the Redis node instead of code\nreturn [{\n  json: {\n    ...$input.first().json,\n    redisKey,\n    conversationHistory: [] // Will be populated by Redis Get node\n  }\n}];"
      },
      "id": "prepare-memory",
      "name": "Prepare Memory Key",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [820, 200]
    },
    {
      "parameters": {
        "model": "claude-haiku-4-5-20251001",
        "messages": {
          "values": [
            {
              "role": "user",
              "content": "=Classify the following WhatsApp message into exactly one intent category. Respond with ONLY a JSON object.\n\nMessage: {{ $json.text }}\nSender: {{ $json.contactName }}\n\nCategories:\n- greeting: Hello, hi, السلام عليكم, مرحبا\n- question: Asking about products, services, pricing, policies\n- booking: Wants to schedule, book, reserve, make an appointment\n- complaint: Unhappy, issue, problem, complaint\n- handoff: Explicitly asks for human, manager, real person\n- purchase: Wants to buy, order, pay\n- unknown: Cannot classify\n\nRespond with: {\"intent\": \"<category>\", \"confidence\": <0-1>, \"language\": \"en|ar\", \"sentiment\": \"positive|neutral|negative\"}"
            }
          ]
        },
        "options": {
          "maxTokens": 150,
          "temperature": 0
        }
      },
      "id": "intent-classifier",
      "name": "Classify Intent (Haiku)",
      "type": "@n8n/n8n-nodes-langchain.lmChatAnthropic",
      "typeVersion": 1,
      "position": [1040, 200],
      "credentials": {
        "anthropicApi": {
          "id": "anthropic-creds",
          "name": "Anthropic API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Parse intent classification result\nconst classificationText = $input.first().json.message?.content || $input.first().json.text || '{}';\nlet classification;\ntry {\n  // Extract JSON from the response\n  const jsonMatch = classificationText.match(/\\{[^}]+\\}/);\n  classification = JSON.parse(jsonMatch ? jsonMatch[0] : classificationText);\n} catch (e) {\n  classification = { intent: 'unknown', confidence: 0, language: 'en', sentiment: 'neutral' };\n}\n\nconst prevData = $('Prepare Memory Key').first().json;\n\nreturn [{\n  json: {\n    ...prevData,\n    intent: classification.intent || 'unknown',\n    confidence: classification.confidence || 0,\n    language: classification.language || 'en',\n    sentiment: classification.sentiment || 'neutral'\n  }\n}];"
      },
      "id": "parse-intent",
      "name": "Parse Classification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1260, 200]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            { "outputIndex": 0, "value": "greeting" },
            { "outputIndex": 1, "value": "question" },
            { "outputIndex": 2, "value": "booking" },
            { "outputIndex": 3, "value": "complaint" },
            { "outputIndex": 4, "value": "handoff" },
            { "outputIndex": 5, "value": "unknown" }
          ]
        },
        "value": "={{ $json.intent }}"
      },
      "id": "intent-router",
      "name": "Route by Intent",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [1480, 200]
    },
    {
      "parameters": {
        "model": "claude-sonnet-4-6-20250514",
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are the WhatsApp assistant for {{COMPANY_NAME}}. The customer sent a greeting. Respond warmly and briefly in their language ({{language}}). Ask how you can help. Keep it to 1-2 sentences."
            },
            {
              "role": "user",
              "content": "={{ $json.text }}"
            }
          ]
        },
        "options": {
          "maxTokens": 200,
          "temperature": 0.7
        }
      },
      "id": "greeting-response",
      "name": "Greeting Response",
      "type": "@n8n/n8n-nodes-langchain.lmChatAnthropic",
