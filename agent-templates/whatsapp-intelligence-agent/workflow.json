    {
      "parameters": {
        "jsCode": "// Generate handoff message\nconst lang = $json.language;\nconst response = lang === 'ar'\n  ? 'سأقوم بتوصيلك مع أحد أعضاء فريقنا الذي يمكنه مساعدتك مباشرة. سيتواصلون معك قريباً.'\n  : 'Let me connect you with a team member who can help with this directly. They\\'ll reach out shortly.';\n\nreturn [{ json: { ...($json), response, escalate: true } }];"
      },
      "id": "handoff-response",
      "name": "Handoff to Human",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1700, 600]
    },
    {
      "parameters": {
        "model": "claude-sonnet-4-6-20250514",
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are the WhatsApp assistant for {{COMPANY_NAME}}. The message intent is unclear. Politely ask the customer to clarify what they need help with. Offer 2-3 suggestions of things you can help with. Respond in the customer's language."
            },
            {
              "role": "user",
              "content": "={{ $json.text }}"
            }
          ]
        },
        "options": {
          "maxTokens": 200,
          "temperature": 0.5
        }
      },
      "id": "fallback-response",
      "name": "Fallback Response",
      "type": "@n8n/n8n-nodes-langchain.lmChatAnthropic",
      "typeVersion": 1,
      "position": [1700, 750],
      "credentials": {
        "anthropicApi": {
          "id": "anthropic-creds",
          "name": "Anthropic API"
        }
      }
