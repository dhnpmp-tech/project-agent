        "messages": {
          "values": [
            {
              "role": "system",
              "content": "={{$env.SYSTEM_PROMPT || 'You are a helpful WhatsApp assistant for {{COMPANY_NAME}}.\\n\\nKnowledge Base:\\n{{KNOWLEDGE_BASE}}\\n\\nAnswer the customer\\'s question using ONLY the knowledge base. If you don\\'t know, say so honestly. Respond in the customer\\'s language. Keep it concise (1-3 short paragraphs).'}}"
