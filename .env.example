# =============================================================================
# Project Agent — Environment Variables
# Copy to .env and fill in values
# =============================================================================

# --- Platform ---
PLATFORM_DOMAIN=yoursystem.com
ACME_EMAIL=admin@yoursystem.com

# --- Master n8n ---
MASTER_N8N_HOST=admin.yoursystem.com
N8N_ENCRYPTION_KEY=           # openssl rand -hex 32
MASTER_DB_USER=n8n_master
MASTER_DB_PASSWORD=           # openssl rand -hex 24

# --- Redis ---
REDIS_PASSWORD=               # openssl rand -hex 24

# --- Supabase (Central DB) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Claude / Anthropic ---
ANTHROPIC_API_KEY=

# --- WhatsApp Business API (via WATI / Interakt) ---
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# --- SendGrid (Email) ---
SENDGRID_API_KEY=

# --- Apollo.io (Lead Enrichment) ---
APOLLO_API_KEY=

# --- Calendar Adapters (Universal Booking) ---
# Google Calendar (OAuth 2.0)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=       # e.g. https://dashboard.yourdomain.com/api/auth/google/callback

# Public website → dashboard API bridge
PUBLIC_WEBSITE_URL=               # e.g. https://here.now (for CORS)
NEXT_PUBLIC_API_URL=              # e.g. https://dashboard.yourdomain.com (used by website booking form)

# Microsoft Outlook / Office 365 (OAuth 2.0 via Azure AD)
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=

# SevenRooms (Restaurant Bookings)
SEVENROOMS_CLIENT_ID=
SEVENROOMS_CLIENT_SECRET=

# Credential encryption key (for storing provider tokens in Supabase)
CALENDAR_ENCRYPTION_KEY=          # openssl rand -hex 32

# --- Calendly (legacy — being replaced by universal calendar adapter) ---
CALENDLY_API_KEY=

# --- Perplexity (Research) ---
PERPLEXITY_API_KEY=

# --- MiniMax M27 (Video/Voice) ---
MINIMAX_API_KEY=

# --- Cloudflare (DNS Management) ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# --- Backup (S3-compatible) ---
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=agent-backups
S3_REGION=me-south-1
